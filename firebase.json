{
  "hosting": {
    "public": "dist",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "/api/chat",
        "function": "chat",
        "region": "us-central1"
      },
      {
        "source": "/api/lead",
        "function": "saveLead",
        "region": "us-central1"
      },
      {
        "source": "/api/contact",
        "function": "saveContact",
        "region": "us-central1"
      },
      {
        "source": "/api/updateLead",
        "function": "updateLead",
        "region": "us-central1"
      },
      {
        "source": "/api/cal-webhook",
        "function": "calWebhook",
        "region": "us-central1"
      },
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  },
  "functions": {
    "source": "functions",
    "codebase": "default",
    "ignore": ["node_modules", ".git", "firebase-debug.log", "firebase-debug.*.log"]
  }
}

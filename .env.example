# Krionics — environment variables
# Copy this file to .env.local and fill in your values.
# .env.local is gitignored and never committed.

# ── Local development only ──────────────────────────────────────────────────
# Point the Vite proxy to your Firebase Emulator.
# Format: http://localhost:5001/YOUR_FIREBASE_PROJECT_ID/us-central1
# Get your project ID from: firebase projects:list
VITE_API_URL=http://localhost:5001/YOUR_PROJECT_ID/us-central1

# ── Production ──────────────────────────────────────────────────────────────
# No env vars needed in production — Firebase Hosting rewrites handle /api/* routing.
# The GROQ_API_KEY is stored as a Firebase Secret (never in this file):
#   firebase functions:secrets:set GROQ_API_KEY
